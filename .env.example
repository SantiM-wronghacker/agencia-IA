# ==========================================
# PLANTILLA DE CONFIGURACIÓN
# Copia a .env.local y completa con tus datos
# ==========================================

# REQUERIDO: Tu API key de Groq
# Obtén la key en: https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_clave_aqui

# API
API_HOST=127.0.0.1
API_PORT=8000

# Modelos LLM (Groq)
MODEL_FAST=llama-3.1-70b-versatile
MODEL_STRONG=llama-3.3-70b-versatile

# Base de datos (Opcional para desarrollo local)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agencia
POSTGRES_PASSWORD=agencia
POSTGRES_DB=agencia_db

# Redis (Opcional para desarrollo local)
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch (Opcional para desarrollo local)
ELASTICSEARCH_URL=http://localhost:9200

# RabbitMQ (Opcional para desarrollo local)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Jaeger Tracing (Opcional para desarrollo local)
JAEGER_COLLECTOR_ENDPOINT=http://localhost:14268/api/traces
JAEGER_ENABLED=false

# Thresholds
DISK_SPACE_THRESHOLD_MB=500
MEMORY_THRESHOLD_MB=256
QUEUE_DEPTH_THRESHOLD=1000

# Timeouts
GROQ_TIMEOUT=30

# Desarrollo
DEBUG=false
DEVELOPMENT=false

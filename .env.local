# ==========================================
# DESARROLLO LOCAL (sin Docker)
# ==========================================

# Groq API - reemplaza con tu key real
GROQ_API_KEY=gsk_tu_key_aqui

# API
API_HOST=127.0.0.1
API_PORT=8000

# Modelos LLM
MODEL_FAST=llama-3.1-70b-versatile
MODEL_STRONG=llama-3.3-70b-versatile

# Base de datos (opcional - los tests usan in-memory)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agencia
POSTGRES_PASSWORD=agencia
POSTGRES_DB=agencia_db

# Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch (opcional)
ELASTICSEARCH_URL=http://localhost:9200

# RabbitMQ (opcional)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Jaeger (opcional)
JAEGER_COLLECTOR_ENDPOINT=http://localhost:14268/api/traces

# Disk space threshold (MB)
DISK_SPACE_THRESHOLD_MB=500

# Memory threshold (MB)
MEMORY_THRESHOLD_MB=256

# Queue depth threshold
QUEUE_DEPTH_THRESHOLD=1000

# Timeout para Groq
GROQ_TIMEOUT=30

# Modo de desarrollo
DEBUG=true
DEVELOPMENT=true

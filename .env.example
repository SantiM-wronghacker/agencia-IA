# ═══════════════════════════════════════════════════════════════
# Agencia IA - Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM API Keys ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GROQ_API_KEY=gsk_your-groq-key
MISTRAL_API_KEY=your-mistral-key
GOOGLE_API_KEY=your-google-key
CEREBRAS_API_KEY=your-cerebras-key

# ─── Database ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agencia_ia
POSTGRES_USER=agencia
POSTGRES_PASSWORD=changeme_in_production

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_production

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=agencia
RABBITMQ_PASSWORD=changeme_in_production
RABBITMQ_VHOST=/

# ─── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ─── Jaeger ───────────────────────────────────────────────────
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# ─── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8080
STREAMLIT_PORT=8501

# ─── Prometheus ───────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Grafana ──────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_production

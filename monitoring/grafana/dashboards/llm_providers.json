{
  "dashboard": {
    "title": "LLM Providers",
    "uid": "agencia-llm-providers",
    "timezone": "browser",
    "panels": [
      {
        "title": "Requests per Provider",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(agencia_llm_provider_requests_total[5m])",
            "legendFormat": "{{provider}} / {{model}}"
          }
        ]
      },
      {
        "title": "Response Times per Provider (p95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(agencia_task_duration_seconds_bucket{task_type=~\"llm_.*\"}[5m]))",
            "legendFormat": "{{task_type}} p95"
          }
        ]
      },
      {
        "title": "Error Rates per Provider",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(agencia_errors_total{agent=~\"llm_.*\"}[5m])",
            "legendFormat": "{{agent}} - {{error_type}}"
          }
        ]
      },
      {
        "title": "Total LLM Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum(agencia_llm_provider_requests_total)",
            "legendFormat": "Total"
          }
        ]
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "30s"
  }
}
